# Fastlane Environment Variables Example
# Copy this file to .env and fill in your values

# App Configuration
APP_IDENTIFIER=com.opd-ai.violence
APPLE_ID=your-apple-id@example.com
TEAM_ID=YOUR_TEAM_ID
ITC_TEAM_ID=YOUR_TEAM_ID

# App Store Connect API (recommended)
ASC_KEY_ID=YOUR_KEY_ID
ASC_ISSUER_ID=YOUR_ISSUER_ID
ASC_KEY_CONTENT=YOUR_KEY_CONTENT_BASE64

# Match (Certificate Management)
MATCH_GIT_URL=https://github.com/opd-ai/violence-certificates
MATCH_PASSWORD=YOUR_MATCH_PASSWORD

# Optional: TestFlight
PILOT_USERNAME=your-apple-id@example.com
