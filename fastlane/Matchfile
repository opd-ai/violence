# Matchfile for Violence Certificate Management

git_url(ENV["MATCH_GIT_URL"] || "https://github.com/opd-ai/violence-certificates")
git_branch("main")

storage_mode("git")

type("appstore")

app_identifier([ENV["APP_IDENTIFIER"] || "com.opd-ai.violence"])

username(ENV["APPLE_ID"] || "your-apple-id@example.com")

